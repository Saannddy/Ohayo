{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ohayo",
  "version": "2.0.0",
  "identifier": "com.ohayo.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "おはよう — API Waker",
        "width": 1300,
        "height": 820,
        "minWidth": 1020,
        "minHeight": 680,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
